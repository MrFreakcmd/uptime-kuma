# =========================================
# Core Server Configuration
# =========================================

# Data directory
DATA_DIR=./data

# Host binding
UPTIME_KUMA_HOST=0.0.0.0
HOST=0.0.0.0

# Server port
UPTIME_KUMA_PORT=3001
PORT=3001

# =========================================
# SSL Configuration
# =========================================

# SSL private key path
UPTIME_KUMA_SSL_KEY=
SSL_KEY=

# SSL certificate path
UPTIME_KUMA_SSL_CERT=
SSL_CERT=

# SSL key passphrase
UPTIME_KUMA_SSL_KEY_PASSPHRASE=
SSL_KEY_PASSPHRASE=

# =========================================
# Cloudflare Tunnel
# =========================================

UPTIME_KUMA_CLOUDFLARED_TOKEN=

# =========================================
# Security
# =========================================

# Disable iframe same-origin protection
UPTIME_KUMA_DISABLE_FRAME_SAMEORIGIN=false

# WebSocket origin validation
# Available values:
# cors-like
# bypass
UPTIME_KUMA_WS_ORIGIN_CHECK=cors-like

# Allow any Chromium executable
UPTIME_KUMA_ALLOW_ALL_CHROME_EXEC=0

# =========================================
# Database Configuration (v2+)
# =========================================

# Database type
# sqlite
# mariadb
UPTIME_KUMA_DB_TYPE=sqlite

# Database hostname
UPTIME_KUMA_DB_HOSTNAME=

# Database port
UPTIME_KUMA_DB_PORT=3306

# Database unix socket
UPTIME_KUMA_DB_SOCKET=

# Database name
UPTIME_KUMA_DB_NAME=

# Database username
UPTIME_KUMA_DB_USERNAME=

# Database password
UPTIME_KUMA_DB_PASSWORD=

# Connection pool size
UPTIME_KUMA_DB_POOL_MAX_CONNECTIONS=10

# =========================================
# Proxy / Networking
# =========================================

# Notification proxy
NOTIFICATION_PROXY=

# Standard proxy environment variables
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# =========================================
# TLS / Certificates
# =========================================

# Additional CA certificates
NODE_EXTRA_CA_CERTS=

# Ignore TLS validation
NODE_TLS_REJECT_UNAUTHORIZED=0

# Node runtime options
NODE_OPTIONS=

# =========================================
# Docker-specific
# =========================================

# User ID
PUID=1000

# Group ID
PGID=1000

# =========================================
# Timezone
# =========================================

TZ=UTC
